# Database (native Homebrew PostgreSQL — uses trust auth by default on macOS)
DATABASE_URL=postgresql+asyncpg://localhost:5432/medtimeline
DATABASE_ENCRYPTION_KEY=<32-byte-hex-key>

# Auth
JWT_SECRET_KEY=<random-64-char-string>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Prompt Builder (prompts are built locally, user can execute externally)
PROMPT_TARGET_MODEL=gemini-3-flash-preview
PROMPT_SUGGESTED_TEMPERATURE=0.3
PROMPT_SUGGESTED_MAX_TOKENS=4096
PROMPT_SUGGESTED_THINKING_LEVEL=low

# AI API (optional — needed for live summarization + text extraction, not for prompt-only mode)
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_TEMPERATURE=0.3
GEMINI_SUMMARY_MAX_TOKENS=8192
GEMINI_CONCURRENCY_LIMIT=10

# Extraction engine (WS-A). Default "hybrid" = ON-DEVICE medspaCy + scispaCy
# fast-path with Gemini escalation for hard sections (faster + keeps PHI off the
# cloud for locally-handled content; ~1.8 GB RAM at startup). Needs the OPTIONAL
# ".[clinical-nlp]" stack — WITHOUT it the pipeline fail-opens to "gemini" (cloud
# LangExtract, no extra load), so installing the stack IS the opt-in. Install:
#   cd backend && pip install -e ".[clinical-nlp]" \
#     && pip install https://s3-us-west-2.amazonaws.com/ai2-s2-scispacy/releases/v0.5.4/en_ner_bc5cdr_md-0.5.4.tar.gz \
#     && python -m spacy download en_core_web_md   # 3.7.x to match spaCy 3.7.5
# Off-switch (shed the load even with the stack installed):
# EXTRACTION_ENGINE=gemini

# Redis (for background jobs)
REDIS_URL=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=./data/uploads
TEMP_EXTRACT_DIR=./data/tmp
MAX_FILE_SIZE_MB=500
MAX_EPIC_EXPORT_SIZE_MB=5000
INGESTION_BATCH_SIZE=100
INGESTION_WORKER_CONCURRENCY=1

# --- Multi-LLM providers ---
# These values are OPERATOR DEFAULTS / FALLBACK. Each user can also manage their
# own provider keys, models, base URLs, and routing in-app at Admin -> System ->
# AI providers (stored encrypted per-user). A user's saved config overrides these;
# anything they leave unset falls back to the values here.
# Provider-agnostic LLM routing. Default "gemini" preserves current behavior.
# Global default provider: gemini | openai | anthropic | openrouter | lmstudio | ollama | vertex
LLM_PROVIDER=gemini
# Optional per-operation overrides (blank => fall back to LLM_PROVIDER).
LLM_SUMMARY_PROVIDER=
LLM_SECTION_PROVIDER=
LLM_DEDUP_PROVIDER=
LLM_EXTRACTION_PROVIDER=
# OpenAI (Apache-2.0 SDK). Key needed only when LLM_PROVIDER=openai.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenRouter (OpenAI-compatible aggregator). Key needed only when LLM_PROVIDER=openrouter.
# OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Ollama (local, OpenAI-compatible server; no key required).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
# LM Studio (local, OpenAI-compatible server; no key required). Blank model => auto-resolved.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=
# Anthropic (MIT SDK). Key needed only when LLM_PROVIDER=anthropic.
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Vertex (Gemini-on-Vertex via google-genai vertexai mode). Set project to enable.
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-3.5-flash

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
